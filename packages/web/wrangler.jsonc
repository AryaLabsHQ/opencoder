{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "opencoder-web",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2025-06-27",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "opencoder.aryalabs.ai",
      "custom_domain": true
    },
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}